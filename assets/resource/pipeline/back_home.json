{
    "进入回家界面": {
        "recognition": {
			"type": "DirectHit",
			"param": {}
		},
		"action": {
			"type": "DoNothing",
			"param": {}
		},
		"next": ["点击回家", "[JumpBack]点击底部菜单并左划"],
		"timeout": 2000
    },
    "点击回家": {
        "recognition": {
			"type": "OCR",
			"param": {
				"roi": [0, 1062, 720, 218],
				"expected": ["回家", "回", "家"]
			}
		},
		"action": {
			"type": "Click",
			"param": {}
		},
		"post_wait_freezes": 5000,
		"next": ["点击日常采购"],
		"timeout": 2000
    },
    "点击日常采购": {
        "recognition": {
			"type": "OCR",
			"param": {
				"expected": ["日常采购", "采购"]
			}
		},
		"action": {
			"type": "Click",
			"param": {}
		},
		"post_delay": 2000,
		"next": ["点击采购零食"],
		"timeout": 2000
    },
    "点击采购零食": {
        "recognition": {
			"type": "OCR",
			"param": {
				"roi": [30, 263, 670, 141],
				"expected": ["零食"]
			}
		},
		"action": {
			"type": "Click",
			"param": {}
		},
		"post_delay": 2000,
		"next": ["点击番茄炒蛋"],
		"timeout": 2000
    },
    "点击番茄炒蛋":{
        "recognition": {
			"type": "OCR",
			"param": {
				"roi": [0, 555, 720, 360],
				"expected": ["番茄炒蛋", "炒蛋"]
			}
		},
		"action": {
			"type": "Click",
			"param": {}
		},
		"next": ["点击购买番茄炒蛋"],
		"timeout": 2000
    },
    "点击购买番茄炒蛋": {
		"recognition": {
			"type": "TemplateMatch",
			"param": {
				"template": "home_gold_corn.png",
                "roi": [351, 936, 369, 145]
			}
		},
		"action": {
			"type": "Click",
			"param": {}
		},
        "repeat": 10,
        "repeat_delay": 500,
		"post_delay": 1000,
		"next": [],
		"timeout": 2000
    }
