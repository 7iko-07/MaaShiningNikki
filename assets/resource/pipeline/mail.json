{
    "邮件任务链入口": {
		"next": ["邮件任务链准备", "[JumpBack]返回主页面"],
		"timeout": 2000
    },
	"邮件任务链准备": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "活动一览按钮.png"
                ],
                "roi": [13, 841, 79, 76]
            }
        },
        "action": {
            "type": "DoNothing",
            "param": {}
        },
        "next": ["点击邮件", "[JumpBack]点击菜单"]
    },
    "点击邮件": {
        "recognition": {
			"type": "OCR",
			"param": {
				"roi": [529, 0, 191, 1054],
				"expected": ["邮件"]
			}
		},
		"action": {
			"type": "Click",
			"param": {}
		},
		"post_wait_freezes": 2000,
		"next": ["点击一键领取邮件"],
		"timeout": 2000
    },
    "点击一键领取邮件": {
        "recognition": {
			"type": "OCR",
			"param": {
				"roi":[60, 680, 605, 366],
				"expected": ["全部领取"]
			}
		},
		"action": {
			"type": "Click",
			"param": {}
		},
		"post_wait_freezes": 2000,
		"next": ["退出邮件列表"],
		"timeout": 2000
    },
    "退出邮件列表": {
		"pre_delay": 1000,
		"recognition": {
			"type": "DirectHit",
			"param": {}
		},
		"action": {
			"type": "Click",
			"param": {
                "target": [227, 1, 168, 98]
            }
		},
		"post_delay": 1000,
		"next": ["stop"],
		"timeout": 2000,
        "repeat": 5,
        "repeat_delay": 500
	}
}